        <string>bash</string>
        <string>-c</string>
        <string>export PATH=/Users/erin/.nvm/versions/node/v20.19.6/bin:$PATH; cd /Users/erin/Desktop/geekeriOS/briefing-runner; npx tsx src/runner.ts evening 2>&amp;1 >> /Users/erin/Desktop/geekeriOS/briefing-runner/logs/evening.log</string>
